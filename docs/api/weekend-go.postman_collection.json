  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/health",
            "description": "Public health check."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('health returns OK', function () {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(pm.response.json().success).to.eql(true);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{userUsername}}\",\n  \"password\": \"{{userPassword}}\",\n  \"nickname\": \"{{userNickname}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register",
            "description": "Registers a normal USER account. Public registration ignores any attempted role field."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('register endpoint is available', function () {",
                  "  pm.expect([201, 409]).to.include(pm.response.code);",
                  "  const body = pm.response.json();",
                  "  if (pm.response.code === 201) {",
                  "    pm.expect(body.data.role).to.eql('USER');",
                  "  } else {",
                  "    pm.expect(body.code).to.eql('USERNAME_ALREADY_EXISTS');",
                  "  }",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{userUsername}}\",\n  \"password\": \"{{userPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login",
            "description": "Logs in the normal user and stores userToken."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('login returns token', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const data = pm.response.json().data;",
                  "  pm.expect(data.token).to.match(/^wg_/);",
                  "  pm.collectionVariables.set('userToken', data.token);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": "{{baseUrl}}/api/auth/me",
            "description": "Returns the current authenticated user."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('me returns USER profile', function () {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(pm.response.json().data.role).to.eql('USER');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Login Admin",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{adminUsername}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login",
            "description": "Requires a pre-created ADMIN user. See docs/api/README.md for local promotion steps."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('admin login returns token', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const data = pm.response.json().data;",
                  "  pm.expect(data.token).to.match(/^wg_/);",
                  "  pm.collectionVariables.set('adminToken', data.token);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Admin Auth Check",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/admin/auth-check",
