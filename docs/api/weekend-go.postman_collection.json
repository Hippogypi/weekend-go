    {
      "name": "Place Discovery",
      "item": [
        {
          "name": "Search Workspaces",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/workspaces/search?keyword={{keyword}}&city={{city}}&page=1&offset=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "workspaces", "search"],
              "query": [
                { "key": "keyword", "value": "{{keyword}}" },
                { "key": "city", "value": "{{city}}" },
                { "key": "page", "value": "1" },
                { "key": "offset", "value": "10" }
              ]
            },
            "description": "Public keyword search. Depends on Amap Web Service availability and key configuration."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('search request is accepted', function () {",
                  "  pm.expect([200, 502, 503]).to.include(pm.response.code);",
                  "});",
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  if (Array.isArray(body.data) && body.data.length > 0) {",
                  "    pm.collectionVariables.set('placeId', String(body.data[0].id));",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Nearby Workspaces",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/workspaces/nearby?longitude={{longitude}}&latitude={{latitude}}&keyword={{keyword}}&radius=1000&page=1&offset=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "workspaces", "nearby"],
              "query": [
                { "key": "longitude", "value": "{{longitude}}" },
                { "key": "latitude", "value": "{{latitude}}" },
                { "key": "keyword", "value": "{{keyword}}" },
                { "key": "radius", "value": "1000" },
                { "key": "page", "value": "1" },
                { "key": "offset", "value": "10" }
              ]
            },
            "description": "Public nearby search. Depends on Amap Web Service availability and key configuration."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('nearby request is accepted', function () {",
                  "  pm.expect([200, 502, 503]).to.include(pm.response.code);",
                  "});",
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  if (Array.isArray(body.data) && body.data.length > 0 && !pm.collectionVariables.get('placeId')) {",
                  "    pm.collectionVariables.set('placeId', String(body.data[0].id));",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Place Detail",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/places/{{placeId}}",
            "description": "Public place detail. Requires placeId from search or manual local setup."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('place detail returns links', function () {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(pm.response.json().data.links.detail).to.include('/api/places/');",
                  "});"
